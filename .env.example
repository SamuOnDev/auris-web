# Copy this file to `.env.local` and fill in real values for local development.
# In production, configure these as Environment Variables in the Vercel project settings.
# Never commit `.env.local` or any file containing real secrets.

# --- Resend (email delivery) ---
RESEND_API_KEY=
FROM_EMAIL="Auris Internacional <noreply@example.com>"
TO_EMAIL=contact@example.com

# Optional fallback used when the primary delivery path fails.
EMERGENCY_FROM_EMAIL=
EMERGENCY_TO_EMAIL=

# --- Google reCAPTCHA v3 ---
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# --- Contact endpoint security ---
# Comma-separated list of origins allowed to POST /api/contact.
CONTACT_ALLOWED_ORIGINS=http://localhost:4321

# --- Optional: n8n webhook integration ---
N8N_WEBHOOK_URL=

# --- Admin panel (/admin) ---
# Bootstrap admin: created on the first successful login, then managed from the panel.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please-min-12-chars
# HMAC session signing secret (>= 32 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-hex-string

# Vercel KV (Upstash Redis) — stores CMS content and admin users.
# Leave empty in dev to use the local-file fallback (.cache/*.json).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob — stores uploaded images. Empty disables uploads (editing by URL still works).
BLOB_READ_WRITE_TOKEN=

# Floating "Admin" button on public pages: keep "false" in dev, set "true" in Vercel prod.
PUBLIC_HIDE_ADMIN_FAB=false
