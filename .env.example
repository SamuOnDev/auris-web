# Copy this file to `.env.local` and fill in real values for local development.
# In production, configure these as Environment Variables in the Vercel project settings.
# Never commit `.env.local` or any file containing real secrets.

# --- Resend (email delivery) ---
RESEND_API_KEY=
FROM_EMAIL="Auris Internacional <noreply@example.com>"
TO_EMAIL=contact@example.com

# Optional fallback used when the primary delivery path fails.
EMERGENCY_FROM_EMAIL=
EMERGENCY_TO_EMAIL=

# --- Google reCAPTCHA v3 ---
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# --- Contact endpoint security ---
# Comma-separated list of origins allowed to POST /api/contact.
CONTACT_ALLOWED_ORIGINS=http://localhost:4321

# --- Optional: n8n webhook integration ---
N8N_WEBHOOK_URL=
