---
import Base from '../../layouts/Base.astro';
import { DEFAULT_LANG, type ActiveLang } from '../../i18n';
import { getCanonicalUrl } from '../../utils/seo';
import { loadCms } from '../../lib/cms-store';
import { makeText, img } from '../../lib/page-content';

const lang = (Astro.params.lang as ActiveLang | undefined) ?? DEFAULT_LANG;
const cms = Astro.locals.cms ?? (await loadCms());
const text = makeText(lang, cms);
const editMode = Astro.locals.editMode ?? false;
const ek = (k: string): string | undefined => (editMode ? k : undefined);

const title = text('seo_about_title');
const description = text('seo_about_description');
const url = getCanonicalUrl(lang, '/about');

const teamMembers = [
  {
    nameKey: 'about_member_ana_name', roleKey: 'about_member_ana_role',
    detailsKey: 'about_member_ana_details', bioKey: 'about_member_ana_bio',
    slot: 'about.esther',
    name: text('about_member_ana_name'),
    role: text('about_member_ana_role'),
    details: text('about_member_ana_details'),
    bio: text('about_member_ana_bio'),
    image: img(cms, 'about.esther', '/team-esther.png'),
    imageWidth: 450,
    imageHeight: 360,
    imageAlt: text('about_member_ana_image_alt'),
  },
  {
    nameKey: 'about_member_javier_name', roleKey: 'about_member_javier_role',
    detailsKey: 'about_member_javier_details', bioKey: 'about_member_javier_bio',
    slot: 'about.javier',
    name: text('about_member_javier_name'),
    role: text('about_member_javier_role'),
    details: text('about_member_javier_details'),
    bio: text('about_member_javier_bio'),
    image: img(cms, 'about.javier', '/team-jordi.jpg'),
    imageWidth: 740,
    imageHeight: 493,
    imageAlt: text('about_member_javier_image_alt'),
  },
];

const contactHref = `/${lang}/contact`;
---
<Base title={title} description={description} url={url} lang={lang}>
  <section class="mx-auto max-w-container px-4 py-10 md:py-16">
    <h1 class="text-3xl font-bold text-white md:text-4xl" data-cms-key={ek('about_title')}>{text('about_title')}</h1>
    <p class="mt-4 max-w-3xl text-lg text-white/80 md:text-xl" data-cms-key={ek('about_intro')}>{text('about_intro')}</p>
  </section>

  <section class="mx-auto max-w-container px-4 pb-16">
    <div class="space-y-12 md:space-y-16">
      <header class="space-y-3">
        <h2 class="text-2xl font-semibold text-white md:text-3xl" data-cms-key={ek('about_team_title')}>{text('about_team_title')}</h2>
        <p class="max-w-3xl text-base text-white/70 md:text-lg" data-cms-key={ek('about_team_intro')}>{text('about_team_intro')}</p>
      </header>

      <div class="space-y-14">
        {teamMembers.map((member, index) => (
          <article
            class="grid grid-cols-1 gap-8 rounded-3xl border border-white/5 bg-white/5 p-6 backdrop-blur md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] md:gap-12 md:p-10"
          >
            <figure
              class={`mx-auto w-full max-w-[280px] overflow-hidden rounded-2xl bg-white/5 shadow-[0_18px_40px_rgba(8,12,32,.35)] sm:max-w-[320px] md:max-w-[360px] md:self-end ${
                index % 2 === 0
                  ? 'md:order-1 md:justify-self-start'
                  : 'md:order-2 md:justify-self-end'
              }`}
            >
              <img
                src={member.image}
                alt={member.imageAlt}
                width={member.imageWidth}
                height={member.imageHeight}
                class="block h-[360px] w-full object-cover object-center sm:h-[420px]"
                loading="lazy"
                decoding="async"
                data-cms-slot={ek(member.slot)}
              />
            </figure>

            <div
              class={`space-y-4 text-left ${
                index % 2 === 0 ? 'md:order-2' : 'md:order-1'
              }`}
            >
              <div class="space-y-3">
                <h3 class="text-2xl font-semibold text-white md:text-[28px]" data-cms-key={ek(member.nameKey)}>{member.name}</h3>
                <p class="text-base font-medium uppercase tracking-wide text-brand-accent/90 md:text-lg" data-cms-key={ek(member.roleKey)}>
                  {member.role}
                </p>
                <p class="text-sm text-white/70 md:text-base" data-cms-key={ek(member.detailsKey)}>{member.details}</p>
              </div>

              <div class="space-y-1 text-sm leading-relaxed text-white/70 md:text-sm text-justify [text-align-last:left] hyphens-auto break-words" data-cms-key={ek(member.bioKey)}>
                {member.bio.split('\n\n').map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Tarjeta CTA final -->
      <div class="cta-card flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <h3 class="text-[22px] md:text-[28px] font-extrabold leading-tight tracking-tight text-white" data-cms-key={ek('about_finalcta_title')}>
            {text('about_finalcta_title')}
          </h3>
          <p class="mt-2 text-white/70 text-sm md:text-base max-w-xl" data-cms-key={ek('about_finalcta_body')}>
            {text('about_finalcta_body')}
          </p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href={contactHref} class="btn-primary" data-cms-key={ek('cta_primary')}>
            {text('cta_primary')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
