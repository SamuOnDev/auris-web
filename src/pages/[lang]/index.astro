---
import Base from '../../layouts/Base.astro';
import { DEFAULT_LANG, type ActiveLang } from '../../i18n';
import { getCanonicalUrl } from '../../utils/seo';
import { loadCms } from '../../lib/cms-store';
import { makeText, img } from '../../lib/page-content';

const lang = (Astro.params.lang as ActiveLang | undefined) ?? DEFAULT_LANG;
const cms = Astro.locals.cms ?? (await loadCms());
const text = makeText(lang, cms);

const title = text('seo_home_title');
const description = text('seo_home_description');
const url = getCanonicalUrl(lang, '/');
const heroPrimaryAlt = text('home_hero_primary_alt');
const heroSecondaryAlt = text('home_hero_secondary_alt');
const heroPrimary = img(cms, 'hero.primary', '/hero.png');
const heroSecondary = img(cms, 'hero.secondary', '/hero_second.jpg');

const contactHref = `/${lang}/contact`;

const specialties = [
  { n: '01', title: text('home_spec_trauma_title'),   desc: text('home_spec_trauma_desc') },
  { n: '02', title: text('home_spec_ansiedad_title'), desc: text('home_spec_ansiedad_desc') },
  { n: '03', title: text('home_spec_animo_title'),    desc: text('home_spec_animo_desc') },
  { n: '04', title: text('home_spec_duelo_title'),    desc: text('home_spec_duelo_desc') },
  { n: '05', title: text('home_spec_tdah_title'),     desc: text('home_spec_tdah_desc') },
  { n: '06', title: text('home_spec_crisis_title'),   desc: text('home_spec_crisis_desc') },
];

const pillars = [
  { n: '01', title: text('home_pillar_team_title'),      desc: text('home_pillar_team_desc') },
  { n: '02', title: text('home_pillar_multilang_title'), desc: text('home_pillar_multilang_desc') },
  { n: '03', title: text('home_pillar_evidence_title'),  desc: text('home_pillar_evidence_desc') },
];
---
<Base title={title} description={description} url={url} lang={lang}>

  <!-- ============================================ -->
  <!-- HERO 1 — con CTAs                            -->
  <!-- ============================================ -->
  <section class="mx-auto max-w-container px-4 py-10 md:py-16">
    <div class="grid grid-cols-1 items-center gap-12 md:min-w-0 md:grid-cols-2 md:gap-14 xl:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="space-y-6 text-left">
        <h1 class="text-[32px] font-extrabold leading-tight tracking-tight text-white sm:text-[40px] md:text-[52px]">
          {text('h1a')} <span class="text-brand-accent">{text('h1b')}</span> {text('h1c')}
        </h1>

        <p class="max-w-xl text-lg text-white/85">
          {text('sub')}
        </p>

        <p class="max-w-xl text-sm text-white/60 sm:text-base">
          {text('sub_alt')}
        </p>

        <div class="pt-4">
          <div class="flex flex-wrap items-center gap-3">
            <a href={contactHref} class="btn-primary">
              {text('cta_primary')}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href={contactHref} class="btn-ghost">
              {text('cta_secondary')}
            </a>
          </div>
          <p class="mt-3 text-xs text-white/45">{text('home_languages_line')}</p>
        </div>
      </div>

      <figure class="justify-self-center md:justify-self-end">
        <div class="mx-auto w-[260px] sm:w-[280px] md:w-[320px] lg:w-[320px]">
          <div class="overflow-hidden rounded-[220px] bg-white/5 shadow-[0_18px_40px_rgba(8,12,32,.45)]">
            <img
              src={heroPrimary}
              alt={heroPrimaryAlt}
              width="323"
              height="523"
              class="block h-[420px] w-full object-cover object-top sm:h-[460px] md:h-[520px]"
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="mx-auto mt-5 h-5 w-2/3 rounded-full bg-white/10 blur-xl"></div>
        </div>
      </figure>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- ESPECIALIDADES                               -->
  <!-- ============================================ -->
  <section class="mx-auto max-w-container px-4 py-10 md:py-20">
    <header class="max-w-3xl mb-10 md:mb-14">
      <p class="eyebrow">{text('home_specialties_eyebrow')}</p>
      <h2 class="text-[28px] sm:text-[34px] md:text-[40px] font-extrabold leading-tight tracking-tight text-white">
        {text('home_specialties_title_a')} <span class="text-brand-accent">{text('home_specialties_title_b')}</span>
      </h2>
      <p class="mt-4 text-white/70 text-base md:text-lg max-w-2xl">
        {text('home_specialties_sub')}
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
      {specialties.map((s) => (
        <article class="spec-card">
          <span class="spec-num">{s.n}</span>
          <h3 class="spec-title">{s.title}</h3>
          <p class="spec-desc">{s.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ============================================ -->
  <!-- HERO 2                                       -->
  <!-- ============================================ -->
  <section class="mx-auto max-w-container px-4 py-10 md:py-16">
    <div class="grid grid-cols-1 items-center gap-12 md:min-w-0 md:grid-cols-2 md:gap-14 xl:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <figure class="order-2 justify-self-center md:order-1 md:justify-self-end">
        <div class="mx-auto w-[280px] sm:w-[320px] md:w-[360px] lg:w-[600px]">
          <div class="aspect-auto overflow-hidden rounded-[16px] bg-white/5 shadow-[0_18px_40px_rgba(8,12,32,.45)]">
            <img
              src={heroSecondary}
              alt={heroSecondaryAlt}
              width="1280"
              height="853"
              class="block h-[420px] w-full object-cover object-top sm:h-[460px] md:h-[520px]"
              loading="eager"
              decoding="async"
            />
          </div>
          <div class="mx-auto mt-5 h-5 w-2/3 rounded-full bg-white/10 blur-xl"></div>
        </div>
      </figure>
      <div class="order-1 space-y-6 text-right md:order-2">
        <h1 class="text-[32px] font-extrabold leading-tight tracking-tight text-white sm:text-[40px] md:text-[52px]">
          {text('h1a2')} <span class="text-brand-accent">{text('h1b2')}</span> {text('h1c2')}
        </h1>
        <p class="max-w-xl ml-auto text-lg text-white/85">
          {text('sub2')}
        </p>
        <p class="max-w-xl ml-auto text-sm text-white/60 sm:text-base">
          {text('sub_alt2')}
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- PILARES + CTA FINAL                          -->
  <!-- ============================================ -->
  <section class="mx-auto max-w-container px-4 py-10 md:py-20">
    <header class="max-w-3xl mb-10 md:mb-14">
      <p class="eyebrow">{text('home_pillars_eyebrow')}</p>
      <h2 class="text-[28px] sm:text-[34px] md:text-[40px] font-extrabold leading-tight tracking-tight text-white">
        {text('home_pillars_title_a')} <span class="text-brand-accent">{text('home_pillars_title_b')}</span>{text('home_pillars_title_c')}
      </h2>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-3 md:divide-x md:divide-white/10 gap-y-2">
      {pillars.map((p, i) => (
        <div class={`pillar ${i === 0 ? 'md:pl-0 md:pr-8' : i === pillars.length - 1 ? 'md:pl-8 md:pr-0' : 'md:px-8'}`}>
          <span class="pillar-num">{p.n}</span>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="cta-card mt-12 md:mt-16 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <h3 class="text-[22px] md:text-[28px] font-extrabold leading-tight tracking-tight text-white">
          {text('home_finalcta_title')}
        </h3>
        <p class="mt-2 text-white/70 text-sm md:text-base max-w-xl">
          {text('home_finalcta_body')}
        </p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a href={contactHref} class="btn-primary">
          {text('cta_primary')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="tel:+34934545417" class="btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          934 54 54 17
        </a>
      </div>
    </div>
  </section>
</Base>
