---
import Base from '../../layouts/Base.astro';
import { DEFAULT_LANG, type ActiveLang } from '../../i18n';
import { getCanonicalUrl } from '../../utils/seo';
import { loadCms } from '../../lib/cms-store';
import { makeText } from '../../lib/page-content';

const lang = (Astro.params.lang as ActiveLang | undefined) ?? DEFAULT_LANG;
const cms = Astro.locals.cms ?? (await loadCms());
const text = makeText(lang, cms);
const editMode = Astro.locals.editMode ?? false;
const ek = (k: string): string | undefined => (editMode ? k : undefined);

const title = text('seo_where_title');
const description = text('seo_where_description');
const url = getCanonicalUrl(lang, '/where');

const ADDRESS_LINE_1 = 'Carrer de Provença, 105, entresuelo, 2ª';
const ADDRESS_LINE_2 = 'Eixample, 08029 Barcelona';
const PHONE_DISPLAY = '934 54 54 17';
const PHONE_LINK = '+34934545417';
const MAP_QUERY = 'Carrer%20de%20Proven%C3%A7a%2C%20105%2C%2008029%20Barcelona';
const MAP_EMBED_SRC = `https://maps.google.com/maps?q=${MAP_QUERY}&output=embed`;
const MAP_DIRECTIONS_URL = `https://maps.google.com/?q=${MAP_QUERY}`;

const contactHref = `/${lang}/contact`;
---
<Base title={title} description={description} url={url} lang={lang}>
  <section class="mx-auto max-w-container px-4 py-12 md:py-20">
    <div class="space-y-10 md:space-y-14">

      <header class="space-y-4 max-w-3xl">
        <h1 class="text-[34px] sm:text-[42px] md:text-[54px] font-extrabold leading-[1.05] tracking-tight text-white" data-cms-key={ek('nav_where')}>
          {text('nav_where')}
        </h1>
        <p class="text-base text-white/80 md:text-lg" data-cms-key={ek('where_intro')}>{text('where_intro')}</p>
      </header>

      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.55fr)_minmax(0,1fr)] lg:items-start">

        <div class="space-y-5">

          <!-- Dirección -->
          <div class="info-card">
            <h2 class="info-eyebrow" data-cms-key={ek('where_address_label')}>{text('where_address_label')}</h2>
            <address class="mt-2 text-lg not-italic leading-relaxed text-white/90">
              {ADDRESS_LINE_1}<br />
              {ADDRESS_LINE_2}
            </address>
            <a href={MAP_DIRECTIONS_URL} target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-1.5 text-sm text-brand-accent hover:underline" data-cms-key={ek('where_directions_link')}>
              {text('where_directions_link')}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </div>

          <!-- Teléfono -->
          <div class="info-card">
            <h2 class="info-eyebrow" data-cms-key={ek('where_phone_label')}>{text('where_phone_label')}</h2>
            <p class="mt-2 text-lg text-white/90">
              <a class="hover:underline" href={`tel:${PHONE_LINK}`}>{PHONE_DISPLAY}</a>
            </p>
            <p class="mt-1 text-sm text-white/55" data-cms-key={ek('where_phone_helper')}>{text('where_phone_helper')}</p>
          </div>

          <!-- Horario -->
          <div class="info-card">
            <h2 class="info-eyebrow" data-cms-key={ek('where_hours_label')}>{text('where_hours_label')}</h2>
            <ul class="mt-2 space-y-1.5 text-white/85 text-[15px]">
              <li class="flex justify-between gap-4 border-b border-white/5 pb-1.5">
                <span data-cms-key={ek('where_hours_weekdays_label')}>{text('where_hours_weekdays_label')}</span><span class="text-white/65" data-cms-key={ek('where_hours_weekdays_value')}>{text('where_hours_weekdays_value')}</span>
              </li>
              <li class="flex justify-between gap-4 border-b border-white/5 pb-1.5">
                <span data-cms-key={ek('where_hours_friday_label')}>{text('where_hours_friday_label')}</span><span class="text-white/65" data-cms-key={ek('where_hours_friday_value')}>{text('where_hours_friday_value')}</span>
              </li>
              <li class="flex justify-between gap-4">
                <span data-cms-key={ek('where_hours_weekend_label')}>{text('where_hours_weekend_label')}</span><span class="text-white/55" data-cms-key={ek('where_hours_weekend_value')}>{text('where_hours_weekend_value')}</span>
              </li>
            </ul>
          </div>

          <!-- Cómo llegar -->
          <div class="info-card">
            <h2 class="info-eyebrow" data-cms-key={ek('where_directions_label')}>{text('where_directions_label')}</h2>
            <ul class="mt-3 space-y-2 text-[15px] text-white/85">
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-accent shrink-0"></span>
                <span data-cms-key={ek('where_directions_metro1')}>{text('where_directions_metro1')}</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-accent shrink-0"></span>
                <span data-cms-key={ek('where_directions_metro2')}>{text('where_directions_metro2')}</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-brand-accent shrink-0"></span>
                <span data-cms-key={ek('where_directions_bus')}>{text('where_directions_bus')}</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Mapa -->
        <div class="overflow-hidden rounded-3xl border border-white/[0.08] bg-white/5 shadow-[0_18px_40px_rgba(8,12,32,.35)]">
          <iframe
            class="block h-[360px] w-full md:h-[480px] lg:h-[640px]"
            src={MAP_EMBED_SRC}
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            title={text('where_map_title')}
          ></iframe>
        </div>
      </div>

      <!-- CTA final -->
      <div class="cta-card flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <h3 class="text-[22px] md:text-[28px] font-extrabold leading-tight tracking-tight text-white" data-cms-key={ek('where_finalcta_title')}>
            {text('where_finalcta_title')}
          </h3>
          <p class="mt-2 text-white/70 text-sm md:text-base max-w-xl" data-cms-key={ek('where_finalcta_body')}>
            {text('where_finalcta_body')}
          </p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href={contactHref} class="btn-primary" data-cms-key={ek('cta_primary')}>
            {text('cta_primary')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href={`tel:${PHONE_LINK}`} class="btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
            {PHONE_DISPLAY}
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
